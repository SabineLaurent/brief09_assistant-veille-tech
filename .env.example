# Application
APP_ENV=development
LOG_LEVEL=INFO

# Azure AI Inference (LLM)
AZURE_AI_INFERENCE_ENDPOINT=
AZURE_AI_INFERENCE_API_KEY=
AZURE_AI_INFERENCE_MODEL=Kimi-K2.6

# Vocabulaire contrôlé des topics (review). Objets {name, gloss} ; gloss optionnel. Absent → défaut du code.
AVAILABLE_TOPICS=[{"name":"AI","gloss":"machine learning, models, LLMs, training/inference, AI research and products."},{"name":"Security","gloss":"vulnerabilities, attacks, defense, cryptography, privacy."},{"name":"Agentic","gloss":"autonomous agents, tool-use, multi-agent systems, agent orchestration."},{"name":"Embedded","gloss":"on-device/edge computing, hardware, IoT, tinyML, firmware."},{"name":"Web","gloss":"web development, front-end, back-end, frameworks, web standards."},{"name":"DevOps","gloss":"CI/CD, deployment, monitoring, observability, cloud-native."}]

# ChromaDB (host port: 8002 ; service-to-service: chromadb:8000)
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=articles
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Backend ↔ Frontend
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# NewsAPI
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

## arXiv
ARXIV_MAX_RESULTS=20
ARXIV_MIN_YEAR=2025
ARXIV_TOPICS=[{"name":"cs.AI","keywords":["LLM","RAG","agent"]}]

## Flux RSS (fresh_news — actu chaude au moment du chat)
# Liste JSON d'objets {url, name} ; feedparser les lit de façon générique. "name" obligatoire.
RSS_FEEDS=[{"url":"https://openai.com/news/rss.xml","name":"OpenAI"},{"url":"https://huggingface.co/blog/feed.xml","name":"Hugging Face"}]
RSS_MAX_ITEMS_PER_FEED=5

## TLDR.tech
# Liste JSON d'éditions à scraper ; "name" = nom de l'édition dans l'URL (https://tldr.tech/<name>/<date>).
TLDR_EDITIONS=[{"name":"ai"},{"name":"infosec"},{"name":"it"},{"name":"design"},{"name":"dev"},{"name":"devops"},{"name":"tech"},{"name":"data"},{"name":"hardware"}]

## GitHub Releases
GITHUB_API_URL=https://api.github.com
GITHUB_RELEASES_TOKEN=
WATCHED_REPOS=[{"owner":"tiangolo","name":"fastapi"},{"owner":"langchain-ai","name":"langchain"}]

# Ingest DB (SQLite checkpoint)
INGEST_DB_PATH=data/ingest.db
