# Application
APP_ENV=development
LOG_LEVEL=INFO

# Azure AI Inference (LLM)
AZURE_AI_INFERENCE_ENDPOINT=
AZURE_AI_INFERENCE_API_KEY=
AZURE_AI_INFERENCE_MODEL=Kimi-K2.6

# ChromaDB (host port: 8002 ; service-to-service: chromadb:8000)
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=articles
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Backend ↔ Frontend
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# NewsAPI
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

## GitHub Releases
GITHUB_API_URL=https://api.github.com
GITHUB_RELEASES_TOKEN=
WATCHED_REPOS=[{"owner":"tiangolo","repo":"fastapi","topic":"python"},{"owner":"langchain-ai","repo":"langchain","topic":"llm"}]

# Ingest DB (SQLite checkpoint)
INGEST_DB_PATH=data/ingest.db
